rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 기본적으로 로그인한 사용자만 접근 가능
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // 조직 정보 (presidia_list): 누구나 읽을 수 있지만(로그인시), 관리는 Admin만
    match /presidia_list/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == '관리자');
    }

    // 사용자 정보 (users): 본인 정보는 수정 가능, 관리자는 모두 읽기/쓰기 가능
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == '관리자');
    }

    // 단원 및 기타 데이터: 로그인한 사용자라면 일단 허용 (추후 데이터별 세부 권한 확장 가능)
    match /members_list/{docId} { allow read, write: if request.auth != null; }
    match /attendance_list/{docId} { allow read, write: if request.auth != null; }
    match /activity_list/{docId} { allow read, write: if request.auth != null; }
    match /ledger_list/{docId} { allow read, write: if request.auth != null; }
    match /officers_list/{docId} { allow read, write: if request.auth != null; }
    match /notice_list/{docId} { allow read, write: if request.auth != null; }
    match /board_list/{docId} { allow read, write: if request.auth != null; }
    match /schedule_list/{docId} { allow read, write: if request.auth != null; }
  }
}
